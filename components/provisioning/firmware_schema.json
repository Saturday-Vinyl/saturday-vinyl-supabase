{
  "version": "0.5.1",
  "device_type": "hub-prototype",
  "capabilities": {
    "wifi": {
      "consumer_input": {
        "type": "object",
        "required": [
          "ssid",
          "password"
        ],
        "properties": {
          "ssid": {
            "type": "string"
          },
          "password": {
            "type": "string"
          }
        }
      },
      "consumer_output": {
        "type": "object",
        "required": [
          "connected"
        ],
        "properties": {
          "rssi": {
            "type": "number",
            "description": "The signal strength of the wifi connection"
          },
          "connected": {
            "type": "boolean",
            "description": "Connection state"
          },
          "ip_address": {
            "type": "string",
            "description": "The local IP address of the device"
          }
        }
      },
      "heartbeat": {
        "type": "object",
        "properties": {
          "wifi_rssi": {
            "type": "integer"
          }
        }
      },
      "tests": {
        "connect": {
          "params": {
            "type": "object",
            "properties": {
              "ssid": {
                "type": "string"
              },
              "password": {
                "type": "string"
              },
              "timeout_ms": {
                "type": "integer",
                "default": 30000
              }
            }
          },
          "result": {
            "type": "object",
            "required": [
              "connected",
              "ip_address",
              "rssi"
            ],
            "properties": {
              "rssi": {
                "type": "number"
              },
              "connected": {
                "type": "boolean"
              },
              "ip_address": {
                "type": "string"
              }
            }
          }
        }
      }
    },
    "thread_br": {
      "factory_output": {
        "type": "object",
        "required": [
          "thread_credentials"
        ],
        "properties": {
          "thread_credentials": {
            "type": "object",
            "required": [
              "pan_id",
              "channel",
              "network_key",
              "network_name",
              "extended_pan_id"
            ],
            "properties": {
              "pan_id": {
                "type": "integer"
              },
              "channel": {
                "type": "integer"
              },
              "network_key": {
                "type": "string"
              },
              "network_name": {
                "type": "string"
              },
              "extended_pan_id": {
                "type": "string"
              }
            },
            "description": "The thread network credentials that are required for other devices to connect to the router"
          }
        }
      },
      "consumer_input": {
        "type": "object",
        "properties": {
          "network_key": {
            "type": "string"
          },
          "network_name": {
            "type": "string"
          }
        }
      },
      "tests": {
        "thread_router_test": {
          "params": {
            "type": "object",
            "properties": {
              "timeout_ms": {
                "type": "integer",
                "default": 60000
              }
            }
          },
          "result": {
            "type": "object",
            "required": [
              "role"
            ],
            "properties": {
              "role": {
                "const": "leader"
              }
            }
          }
        }
      }
    },
    "cloud": {
      "factory_input": {
        "type": "object",
        "required": [
          "cloud_url",
          "cloud_anon_key"
        ],
        "properties": {
          "cloud_url": {
            "type": "string"
          },
          "cloud_anon_key": {
            "type": "string"
          }
        }
      },
      "tests": {
        "ping": {
          "params": {
            "type": "object",
            "properties": {
              "timeout_ms": {
                "type": "integer",
                "default": 15000
              }
            }
          }
        }
      }
    },
    "rfid": {
      "factory_input": {
        "type": "object",
        "properties": {
          "power_dbm": {
            "type": "integer"
          }
        }
      },
      "tests": {
        "scan": {
          "params": {
            "type": "object",
            "properties": {
              "duration_ms": {
                "type": "integer",
                "default": 5000
              }
            }
          }
        }
      }
    },
    "ble": {
      "tests": {
        "ble_test": {}
      }
    },
    "button": {
      "tests": {
        "press": {
          "params": {
            "type": "object",
            "properties": {
              "timeout_ms": {
                "type": "integer",
                "default": 30000
              }
            }
          }
        }
      }
    },
    "websocket": {
      "heartbeat": {
        "type": "object",
        "required": [
          "websocket_connected"
        ],
        "properties": {
          "websocket_connected": {
            "type": "boolean"
          }
        }
      },
      "tests": {
        "websocket_test": {}
      }
    }
  }
}
