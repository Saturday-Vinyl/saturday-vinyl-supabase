menu "Saturday Vinyl Hub Configuration"

    config SV_HUB_LOG_LEVEL
        int "Default log level (0=None, 1=Error, 2=Warn, 3=Info, 4=Debug, 5=Verbose)"
        default 3
        range 0 5
        help
            Set the default logging level for Saturday Hub components.

    menu "RFID Configuration"
        config SV_RFID_POLL_INTERVAL_MS
            int "RFID poll interval (ms)"
            default 500
            range 100 5000
            help
                Time between RFID polling attempts in milliseconds.

        config SV_RFID_POWER_DBM
            int "RFID RF power (dBm)"
            default 10
            range 0 30
            help
                RF output power for RFID module in dBm.

        config SV_RFID_DEBOUNCE_PRESENT_MS
            int "Tag present debounce time (ms)"
            default 1000
            range 0 5000
            help
                Time a tag must be present before confirming detection.

        config SV_RFID_DEBOUNCE_ABSENT_MS
            int "Tag absent debounce time (ms)"
            default 2000
            range 0 10000
            help
                Time a tag must be absent before confirming removal.
    endmenu

    menu "LED Configuration"
        config SV_LED_DEFAULT_BRIGHTNESS
            int "Default LED brightness (0-255)"
            default 128
            range 0 255
            help
                Default brightness level for the RGB LED.
    endmenu

endmenu
